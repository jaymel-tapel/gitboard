# GitBoard Server Configuration
# Copy this file to .env and adjust values as needed

# Server port (default: 3456)
PORT=3456

# Path to the git repository containing the gitboard folder
# If not set, auto-detects by walking up from current directory
# GITBOARD_REPO_PATH=/path/to/your/repo

# Node environment (development/production)
NODE_ENV=development

# Ollama base URL for docs agent embeddings (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
